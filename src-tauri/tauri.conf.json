{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "trace",
  "version": "0.1.0",
  "identifier": "com.obsidianos.trace",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "trace",
        "width": 1280,
        "height": 832,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/noble1911/trace/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE4NzQ1RUM1MTA5RjA5RkUKUldUK0NaOFF4VjUwR1Ayd1UrYkZiZGxISi9zcDR6RTRoYjlVNjQ3eVdUMk9sUlpZVDY4MXNpOTQK"
    }
  }
}
